# Web app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE=/.netlify/functions
NEXT_PUBLIC_CHROME_STORE_URL=
NEXT_PUBLIC_EDGE_STORE_URL=
NEXT_PUBLIC_FIREFOX_AMO_URL=
NEXT_PUBLIC_SAFARI_URL=
PUBLIC_BASE_URL=http://localhost:8888
DATABASE_URL=postgresql://user:pass@localhost:5432/holmeta?sslmode=require
HOLMETA_MONITOR_WEBHOOK_URL=
NEXT_PUBLIC_ENABLE_CLIENT_MONITORING=true

# Stripe + licensing
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_MONTHLY_A=price_REPLACE_ME
STRIPE_PRICE_MONTHLY_B=price_REPLACE_ME
STRIPE_PRICE_YEARLY=price_REPLACE_ME
# Legacy fallback (optional): if STRIPE_PRICE_MONTHLY_A is empty, STRIPE_PRICE_ID_2 is used.
STRIPE_PRICE_ID_2=
TRIAL_DAYS=3
LICENSE_SALT=replace-with-long-random-secret

# Extension defaults
HOLMETA_API_BASE_URL=https://your-netlify-site.netlify.app
HOLMETA_VALIDATE_LICENSE_URL=https://your-netlify-site.netlify.app/.netlify/functions/validate-license
HOLMETA_CHECKOUT_URL=https://your-netlify-site.netlify.app/.netlify/functions/create-checkout-session
HOLMETA_DASHBOARD_URL=https://your-netlify-site.netlify.app/dashboard
HOLMETA_DEV_BYPASS_PREMIUM=false
