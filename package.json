{
  "name": "holmeta",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint:css-integrity": "node scripts/check-css-integrity.mjs",
    "verify:netlify-env": "node scripts/verify-netlify-env.mjs",
    "e2e:smoke": "node scripts/e2e-smoke.mjs",
    "qa:extension-runtime": "node scripts/extension-runtime-smoke.mjs",
    "db:migrate": "node scripts/run-migrations.mjs",
    "build:extension:zip": "node scripts/sync-extension-zip.mjs",
    "validate:extension": "npm run validate:extension -w @holmeta/extension",
    "dev:web": "npm run dev -w @holmeta/web",
    "dev:extension": "npm run dev -w @holmeta/extension",
    "build:extension": "npm run build -w @holmeta/extension",
    "zip:extension": "npm run zip -w @holmeta/extension"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "eslint": "^8.57.1",
    "playwright": "^1.58.2",
    "typescript": "^5.7.3"
  }
}
